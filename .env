# ── Browser ───────────────────────────────────────────────────────────────────
# false = visible window, true = run invisibly
HEADLESS=false

# Slow down every browser action by N ms — helps bypass bot detection (try 50-150)
SLOW_MO=0

# Set to true to route traffic through the proxy below
PROXY_ENABLED=false

# Webshare rotating proxy — fill in your credentials from webshare.io dashboard
# Format: http://<username>:<password>@p.webshare.io:3128  (port 3128 for HTTPS CONNECT)
PROXY_URL=http://cvtaqxhe:2gbqnve2k51q@p.webshare.io:3128

# ── Crawlee crawler ───────────────────────────────────────────────────────────
# Keeps session cookies across runs so solved bot challenges persist.
# Crawlee reads this env var at import time — do not change to code-based config.
CRAWLEE_PURGE_ON_START=false
# Parallel browser contexts (Crawlee auto-scales up to this limit)
CONCURRENCY=1

# Attempts per SKU before marking as failed (Crawlee handles retry backoff internally)
RETRY_COUNT=2

# ── Timing ────────────────────────────────────────────────────────────────────
# Per-page navigation timeout in milliseconds
PAGE_TIMEOUT=30000

# Sleep after page load before extraction (base ms; up to +1000ms random jitter added)
SLEEP_BASE_MS=1500

# ── Output paths ──────────────────────────────────────────────────────────────
CSV_PATH=product_data.csv
ERROR_LOG=errors.log
SKUS_PATH=skus.json
